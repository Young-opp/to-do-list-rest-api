{% extends 'base.html.twig' %}

{% block title %}Add New To-Do{% endblock %}

{% block body %}
<h1 class="mb-3">Create New Task</h1>

{{ form_start(form) }}
    <div class="mb-3">
        {{ form_row(form.title, {'attr': {'class': 'form-control'}}) }}
    </div>
    <div class="mb-3">
        {{ form_row(form.description, {'attr': {'class': 'form-control'}}) }}
    </div>
    <div class="form-check mb-3">
        {{ form_row(form.isCompleted, {'attr': {'class': 'form-check-input'}}) }}
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
{{ form_end(form) }}

<a href="{{ path('todo_list') }}" class="btn btn-secondary mt-3">⬅ Back to List</a>
{% endblock %}